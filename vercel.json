{
  "version": 2,
  "builds": [
    { "src": "index.php", "use": "vercel-php@0.7.3" },
    { "src": "register.php", "use": "vercel-php@0.7.3" },
    { "src": "register_process.php", "use": "vercel-php@0.7.3" },
    { "src": "admin/*.php", "use": "vercel-php@0.7.3" },
    { "src": "staff/*.php", "use": "vercel-php@0.7.3" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ]
}